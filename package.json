{
    "name": "claude-code-template",
    "version": "1.0.0",
    "description": "Template repository for starting Claude Code projects with skills and best practices",
    "main": "src/index.js",
    "scripts": {
        "start": "node src/index.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src/**/*.js",
        "lint:fix": "eslint src/**/*.js --fix"
    },
    "keywords": [
        "claude-code",
        "template",
        "ai-assisted-development",
        "skills"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "jest": "^29.0.0"
    },
    "jest": {
        "testEnvironment": "node",
        "coverageDirectory": "coverage",
        "collectCoverageFrom": [
            "src/**/*.js",
            "!src/**/*.test.js"
        ]
    }
}